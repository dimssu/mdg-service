# ── ElevenLabs voiceover ─────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your key. `.env` is git-ignored.

# Your ElevenLabs API key (Profile → API Keys).
ELEVENLABS_API_KEY=

# The voice that reads the Hindi narration. Pick a natural HINDI / Indian voice
# from your ElevenLabs Voice Library and paste its Voice ID here.
# (Any voice works with the multilingual model, but an Indian voice sounds best.)
ELEVENLABS_VOICE_ID=

# Model. eleven_multilingual_v2 speaks Hindi well and is widely available.
# eleven_turbo_v2_5 is cheaper/faster and also supports Hindi.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Output audio quality. mp3_44100_128 = 128 kbps, good for video.
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
