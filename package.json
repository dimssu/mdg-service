{
  "name": "dealer-kavach",
  "version": "0.1.0",
  "private": true,
  "description": "Dealer Kavach admin portal - dealer onboarding and recurring service orchestration.",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "shared",
    "mdg-backend",
    "mdg-admin",
    "mdg-client"
  ],
  "scripts": {
    "dev": "concurrently -k -n backend,admin,client -c blue,magenta,cyan \"npm --workspace mdg-backend run dev\" \"npm --workspace mdg-admin run dev\" \"npm --workspace mdg-client run dev\"",
    "build": "npm --workspace shared run build && npm --workspace mdg-backend run build && npm --workspace mdg-admin run build && npm --workspace mdg-client run build",
    "seed": "npm --workspace mdg-backend run seed",
    "test": "npm --workspaces --if-present run test",
    "lint": "eslint \"mdg-backend/src/**/*.{ts,tsx}\" \"mdg-admin/src/**/*.{ts,tsx}\" \"mdg-client/src/**/*.{ts,tsx}\" \"shared/src/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"mdg-backend/src/**/*.{ts,tsx}\" \"mdg-admin/src/**/*.{ts,tsx}\" \"mdg-client/src/**/*.{ts,tsx}\" \"shared/src/**/*.ts\" --fix",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "rimraf \"**/dist\" \"**/*.tsbuildinfo\"",
    "prepare": "node -e \"try { require('fs').accessSync('.git'); require('child_process').execSync('husky', { stdio: 'inherit' }); } catch (e) {}\""
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "concurrently": "^9.0.1",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4"
  }
}
